# Neon pooled connection string for the Next.js runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Neon direct connection string for Prisma CLI commands such as migrate.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Optional Auth.js v5 configuration. Guest mode is the default when these are empty.
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# HMAC secret for anonymous participation keys. Set a strong value in production.
ANON_KEY_SECRET=""

# E2E only. Never enable in production. "1" enables the test credentials provider.
AUTH_TEST_LOGIN=""

# Server-side OpenAI-compatible Responses configuration.
GMS_API_KEY=""
GMS_API_URL="https://gms.ssafy.io/gmsapi/api.openai.com/v1/responses"

# Optional direct OpenAI Responses credential for Decision Room execution.
# Configure this or GMS_API_KEY; never expose either key to the browser.
OPENAI_API_KEY=""

# Pre-existing draft normalization and merge pipeline.
GMS_DEFAULT_MODEL="gpt-4.1"

# OpenAI Build Week Decision Room. Provider-neutral and auditable.
DECISION_MODEL="gpt-5.6"

# Compatibility alias for older GMS-specific deployments. DECISION_MODEL takes precedence.
GMS_DECISION_MODEL="gpt-5.6"

# Optional Upstash Redis REST configuration. Empty values use the in-memory fallback.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
